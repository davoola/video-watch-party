# 服务器端口
PORT=3000

# 站点名称：显示在浏览器标签页标题、首页顶部品牌区等位置。不设置则默认为"私密影院"。
SITE_NAME=私密影院

# Session 加密密钥：务必改成一个随机长字符串
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=请替换成你自己的随机长字符串

# 视频根目录（绝对路径），程序会递归扫描这个目录下的所有视频文件
VIDEO_DIR=/absolute/path/to/your/videos

# 运行环境：development 或 production
NODE_ENV=development

# 是否信任反向代理（nginx / Caddy 等）传来的 X-Forwarded-* 头。
# 只有在前面确实有反向代理时才能设为 true，否则客户端可以伪造这些头，
# 冒充任意来源 IP，或让服务器误以为连接是 HTTPS，存在安全隐患。
#
# 直接用 npm start 跑、没有反向代理：保持 false
# 用 nginx/Caddy 反代（无论反代是否已配 HTTPS）：设为 true
TRUST_PROXY=false

# 聊天图片保留天数：超过这个天数没被更新的上传图片会被自动清理（每天检查一次）。
# 设为 0 可以关闭自动清理，永久保留所有上传过的图片。
CHAT_IMAGE_RETENTION_DAYS=30
